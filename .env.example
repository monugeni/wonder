# Required — your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# LLM model for context enrichment and tree summaries (default: claude-haiku-4-5-20251001)
# CONTEXT_MODEL=claude-haiku-4-5-20251001

# Qdrant connection (default: localhost:6333)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Embedding model (default: BAAI/bge-base-en-v1.5)
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Directory for table JSON artifacts (default: ./table_store)
# TABLE_STORE_DIR=./table_store

# Log level (default: INFO)
# LOG_LEVEL=INFO
